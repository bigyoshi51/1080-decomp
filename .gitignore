# Expected .o files are checked in (see expected/) — do not ignore
!expected/**/*.o

# decomp-permuter scratch dirs (transient, per-function search state).
# Anchored at root so `asm/nonmatchings/` (the real splat-extracted asm
# tree) isn't accidentally ignored. (A stray unanchored `nonmatchings/`
# line crept back in and re-ignored asm/nonmatchings — removed 2026-06-09;
# keep ONLY the anchored form.)
/nonmatchings/

# Auxiliary USO-symbol placeholder files generated by
# scripts/uso-reloc-symbolize.py (not used by the current build — would
# be needed for the spimdisasm USO-reloc migration; regenerate on demand).
*.usosyms.txt
uoptlist
